{
  "name": "portmaster",
  "private": true,
  "version": "0.0.0",
  "description": "PortMaster desktop app for managing localhost services and Docker containers.",
  "author": "xiangzai",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:desktop\"",
    "dev:renderer": "vite",
    "dev:desktop": "wait-on tcp:5173 && node ./node_modules/cross-env/dist/bin/cross-env.js VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "generate:icons": "node ./scripts/generate-icons.mjs",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "desktop:preview": "node ./node_modules/cross-env/dist/bin/cross-env.js NODE_ENV=production electron .",
    "dist:desktop": "npm run dist:mac:arm64",
    "dist:mac": "npm run dist:mac:arm64",
    "dist:mac:arm64": "npm run generate:icons && npm run build && node ./node_modules/cross-env/dist/bin/cross-env.js CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64",
    "dist:mac:x64": "npm run generate:icons && npm run build && node ./node_modules/cross-env/dist/bin/cross-env.js CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --x64",
    "dist:win": "npm run dist:win:arm64",
    "dist:win:arm64": "npm run generate:icons && npm run build && node ./node_modules/cross-env/dist/bin/cross-env.js CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis zip portable --arm64",
    "dist:win:x64": "npm run generate:icons && npm run build && node ./node_modules/cross-env/dist/bin/cross-env.js CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis zip portable --x64",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "react-simple-code-editor": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.portmaster.desktop",
    "productName": "PortMaster",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "icon.icns",
      "identity": null,
      "category": "public.app-category.developer-tools",
      "artifactName": "PortMaster-${version}-macos-${arch}.${ext}",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "icon.ico",
      "artifactName": "PortMaster-${version}-windows-${arch}.${ext}",
      "target": ["nsis", "portable", "zip"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "PortMaster-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "PortMaster-${version}-windows-${arch}-portable.${ext}"
    }
  }
}
